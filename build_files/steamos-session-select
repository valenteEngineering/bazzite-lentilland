#!/usr/bin/bash
# =======================================================================================
# Patched steamos-session-select for bazzite-lentilland.
# Adds a `hyprland` target and makes `desktop`/`plasma` resolve to Hyprland (Hyprland is
# our desktop now). `gamescope` unchanged. `gnome` kept as an escape hatch.
#
#   steamos-session-select hyprland   -> boot into Hyprland (persistent)
#   steamos-session-select gamescope  -> boot into Steam Gaming Mode
#   steamos-session-select gnome      -> boot into stock GNOME (fallback)
# =======================================================================================
set -e

die() { echo >&2 "!! $*"; exit 1; }

IMAGE_INFO="/usr/share/ublue-os/image-info.json"
BASE_IMAGE_NAME=$(jq -r '."base-image-name"' < "$IMAGE_INFO")

CONF_FILE="/etc/sddm.conf.d/zz-steamos-autologin.conf"
SENTINEL_FILE="steamos-session-select"
CHECK_FILE="/etc/sddm.conf.d/steamos.conf"

session="${1:-gamescope}"
session_type="wayland"

if [[ "$2" == "--sentinel-created" ]]; then
  SENTINEL_CREATED=1
fi

if [[ -z ${SENTINEL_CREATED:-} ]]; then
  [[ $EUID == 0 ]] && die "Running $0 as root is not allowed"
  [[ -n ${HOME+x} ]] || die "No \$HOME variable"
  config_dir="${XDG_CONF_DIR:-"$HOME/.config"}"
  session_type=$(
    cd "$HOME"
    mkdir -p "$config_dir"
    cd "$config_dir"
    if [[ -f "steamos-session-type" ]]; then
      cp steamos-session-type "$SENTINEL_FILE"
    else
      echo "wayland" > "$SENTINEL_FILE"
    fi
    cat "$SENTINEL_FILE"
  )
  export SENTINEL_CREATED=1
fi

session_launcher=""
case "$session" in
  hyprland|desktop|plasma)
    session_launcher="hyprland.desktop"
  ;;
  gnome)
    session_launcher="gnome-wayland.desktop"
  ;;
  gamescope)
    session_launcher="gamescope-session.desktop"
  ;;
  *)
    echo >&2 "!! Unrecognized session '$session'"
    exit 1
  ;;
esac

echo "Updated user selected session to $session_launcher"

if [[ $EUID != 0 ]]; then
  exec pkexec "$(realpath "$0")" "$session" --sentinel-created "$session_type"
  exit 1
fi

{
  echo "[Autologin]"
  echo "Session=$session_launcher"
} > "$CONF_FILE"

echo "Updated system autologin session to $session_launcher"
systemctl reset-failed sddm
systemctl restart sddm
echo "Restarted SDDM"
